{
  "manifest_version": 3,
  "name": "SafeStride AI - Link Guard",
  "version": "1.0",
  "description": "Scam links ko click hone se pehle rokta hai.",
  "permissions": ["declarativeNetRequest", "tabs", "notifications"],
  "host_permissions": ["http://localhost:3000/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
